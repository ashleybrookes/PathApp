@page "/"
@page "/path-viewer"
@using PathDrift.Shared.Interfaces
@using PathDrift.Shared.Models
@using PathViewingApp.Services
@implements IDisposable
@inject ICoordinateStore Store
@inject PathViewerLogic Logic
@rendermode InteractiveServer
@using PathViewingApp.Components

<PageTitle>Path Drift Viewer</PageTitle>

<h1>Path Drift Visualisation</h1>

<div class="controls">
    <button class="btn @(ActivePlane == PathViewerLogic.Plane.XY ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetPlane(PathViewerLogic.Plane.XY)">X-Y</button>
    <button class="btn @(ActivePlane == PathViewerLogic.Plane.XZ ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetPlane(PathViewerLogic.Plane.XZ)">X-Z</button>
    <button class="btn @(ActivePlane == PathViewerLogic.Plane.YZ ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetPlane(PathViewerLogic.Plane.YZ)">Y-Z</button>
    <span class="ms-3 text-muted">Points: @_coordinates.Count</span>
</div>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger mt-3">@_errorMessage</div>
}

@if (_coordinates.Count == 0)
{
    <div class="alert alert-info mt-3">
        Waiting for coordinate data from the primary service...
    </div>
}
else
{
    <ErrorBoundary>
        <ChildContent>
            <svg width="@PathViewerLogic.SvgWidth" height="@PathViewerLogic.SvgHeight" class="mt-3 border rounded" style="background: #1a1a2e;">
                @* Axis labels *@
                @((MarkupString)$"<text x=\"{PathViewerLogic.SvgWidth / 2}\" y=\"{PathViewerLogic.SvgHeight - 5}\" fill=\"#aaa\" text-anchor=\"middle\" font-size=\"12\">{Logic.GetHAxisLabel(ActivePlane)}</text>")
                @((MarkupString)$"<text x=\"12\" y=\"{PathViewerLogic.SvgHeight / 2}\" fill=\"#aaa\" text-anchor=\"middle\" font-size=\"12\" transform=\"rotate(-90, 12, {PathViewerLogic.SvgHeight / 2})\">{Logic.GetVAxisLabel(ActivePlane)}</text>")

                @* Path polyline *@
                <polyline points="@Logic.GetPolylinePoints(_coordinates, ActivePlane, _minH, _maxH, _minV, _maxV)" fill="none" stroke="#00d4ff" stroke-width="1.5" stroke-linejoin="round" />

                @* Start and end markers *@
                @if (_coordinates.Count > 0)
                {
                    var (sx, sy) = Logic.ScalePoint(_coordinates[0], ActivePlane, _minH, _maxH, _minV, _maxV);
                    var (ex, ey) = Logic.ScalePoint(_coordinates[^1], ActivePlane, _minH, _maxH, _minV, _maxV);
                    <circle cx="@sx" cy="@sy" r="5" fill="#00ff88" />
                    <circle cx="@ex" cy="@ey" r="5" fill="#ff4444" />
                    @((MarkupString)$"<text x=\"{sx + 8}\" y=\"{sy - 5}\" fill=\"#00ff88\" font-size=\"10\">Start</text>")
                    @((MarkupString)$"<text x=\"{ex + 8}\" y=\"{ey - 5}\" fill=\"#ff4444\" font-size=\"10\">End</text>")
                }
            </svg>
        </ChildContent>
        <ErrorContent Context="renderEx">
            <div class="alert alert-danger mt-3">
                Visualisation error: @renderEx.Message
            </div>
        </ErrorContent>
    </ErrorBoundary>
}

<CoordinateDataTable />

@code {
    private List<Coordinate> _coordinates = [];
    private double _minH, _maxH, _minV, _maxV;
    private string? _errorMessage;

    private PathViewerLogic.Plane ActivePlane { get; set; } = PathViewerLogic.Plane.XY;

    protected override void OnInitialized()
    {
        Store.OnUpdated += HandleDataUpdated;
        RefreshData();
    }

    private void SetPlane(PathViewerLogic.Plane plane)
    {
        ActivePlane = plane;
        RefreshData();
    }

    private void HandleDataUpdated()
    {
        InvokeAsync(() =>
        {
            try
            {
                RefreshData();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                _errorMessage = $"Failed to update display: {ex.Message}";
                StateHasChanged();
            }
        });
    }

    private void RefreshData()
    {
        _coordinates = Store.Coordinates.ToList();
        if (_coordinates.Count == 0) return;

        (_minH, _maxH, _minV, _maxV) = Logic.ComputeBounds(_coordinates, ActivePlane);
    }

    public void Dispose()
    {
        Store.OnUpdated -= HandleDataUpdated;
    }
}

